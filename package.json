{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "discolink",
  "type": "module",
  "version": "4.6.2",
  "description": "A Lavalink client for Discord bots in TypeScript",
  "exports": {
    "import": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "require": {
      "types": "./lib/index.d.cts",
      "default": "./lib/index.cjs"
    }
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "./lib/",
    "NOTICE"
  ],
  "author": "Aman (https://github.com/execaman)",
  "funding": "https://github.com/sponsors/execaman",
  "repository": "https://github.com/execaman/discolink",
  "homepage": "https://execaman.github.io/discolink",
  "bugs": "https://github.com/execaman/discolink/issues",
  "keywords": [
    "audio",
    "player",
    "client",
    "discord",
    "lavalink"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "lint": "prettier --check . && tsc --noEmit",
    "test": "vitest run",
    "build": "tsdown",
    "format": "prettier --log-level error --write .",
    "docs:dev": "astro dev --root docs",
    "docs:build": "astro build --root docs && typedoc --options docs/typedoc.json",
    "docs:preview": "astro preview --root docs",
    "deps": "ncu --format group --dep",
    "upgrade": "ncu -u && npm update",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=22.22"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.39.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "astro": "^6.3.1",
    "husky": "^9.1.7",
    "npm-check-updates": "^21.0.2",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsdown": "^0.21.8",
    "typedoc": "^0.28.19",
    "typedoc-material-theme": "^1.4.1",
    "typedoc-plugin-dt-links": "^2.0.53",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
