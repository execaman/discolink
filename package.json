{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "discolink",
  "type": "module",
  "version": "5.0.0",
  "description": "A Lavalink client for Discord bots in TypeScript",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Aman (https://github.com/execaman)",
  "funding": "https://github.com/sponsors/execaman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/execaman/discolink.git"
  },
  "homepage": "https://execaman.github.io/discolink",
  "bugs": "https://github.com/execaman/discolink/issues",
  "keywords": [
    "audio",
    "player",
    "client",
    "discord",
    "lavalink"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "./dist",
    "NOTICE"
  ],
  "workspaces": [
    "./docs"
  ],
  "scripts": {
    "lint": "prettier --check . && tsc --noEmit",
    "test": "vitest run",
    "build": "tsdown",
    "format": "prettier --log-level error --write .",
    "docs:dev": "npm -w docs run dev",
    "docs:build": "npm -w docs run build",
    "docs:preview": "npm -w docs run preview",
    "deps": "ncu --format group --dep",
    "upgrade": "ncu -u && npm install",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "npm-check-updates": "^22.2.3",
    "prettier": "^3.8.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
